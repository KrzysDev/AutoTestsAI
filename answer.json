"{\n  \"groups\": [\n    {\n      \"questions\": [\n        {\n          \"text\": \"When the phone rang, I ___ dinner. a) cooked b) was cooking c) had cooked d) have cooked\",\n          \"type\": \"multiple_choice\",\n          \"correct_answer\": \"b\"\n        },\n        {\n          \"text\": \"By the time we arrived, they ___ the meeting. a) started b) were starting c) had started d) have started\",\n          \"type\": \"multiple_choice\",\n          \"correct_answer\": \"c\"\n        },\n        {\n          \"text\": \"She ___ to the gym every day when she was younger. a) goes b) went c) used to go d) was going\",\n          \"type\": \"multiple_choice\",\n          \"correct_answer\": \"c\"\n        },\n        {\n          \"text\": \"Before I moved to Warsaw, I ___ in Krakow for 10 years. a) lived b) was living c) had lived d) had been living\",\n          \"type\": \"multiple_choice\",\n          \"correct_answer\": \"d\"\n        },\n        {\n          \"text\": \"While I ___ the report, the power went out. a) wrote b) was writing c) had written d) have written\",\n          \"type\": \"multiple_choice\",\n          \"correct_answer\": \"b\"\n        }\n      ],\n      \"answers\": [\"b\", \"c\", \"c\", \"d\", \"b\"]\n    },\n    {\n      \"questions\": [\n        {\n          \"text\": \"She __________ (not/realize) that she had lost her keys until she got home.\",\n          \"type\": \"open_ended\",\n          \"correct_answer\": \"did not realize\"\n        },\n        {\n          \"text\": \"When I was a child, I __________ (spend) most summers at my grandparents' house.\",\n          \"type\": \"open_ended\",\n          \"correct_answer\": \"spent\"\n        },\n        {\n          \"text\": \"By 8 PM yesterday, we __________ (finish) the project.\",\n          \"type\": \"open_ended\",\n          \"correct_answer\": \"had finished\"\n        },\n        {\n          \"text\": \"The children __________ (play) in the garden when it started to rain.\",\n          \"type\": \"open_ended\",\n          \"correct_answer\": \"were playing\"\n        },\n        {\n          \"text\": \"Before moving to London, she __________ (live) in Paris for over ten years.\",\n          \"type\": \"open_ended\",\n          \"correct_answer\": \"had been living\"\n        }\n      ],\n      \"answers\": [\"did not realize\", \"spent\", \"had finished\", \"were playing\", \"had been living\"]\n    }\n  ]\n}"